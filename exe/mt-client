#!/usr/bin/env ruby
begin
  require "bundler/setup"
rescue LoadError, Bundler::GemNotFound
  # Running outside bundler (e.g., gem install or JRuby without dev deps)
end
require "optparse"

def add_connection_options(opts, options)
  opts.on("--uri-file PATH", "URI file location") do |v|
    options[:uri_file] = v
  end

  opts.on("-s", "--seed SEED", Integer, "Random seed") do |v|
    options[:seed] = v
  end
end

def add_filter_options(opts, options)
  opts.on("-i", "--include PATTERN", "Include filter (/regexp/ or string)") do |v|
    options[:include_filter] = v
  end

  opts.on("-e", "--exclude PATTERN", "Exclude filter") do |v|
    options[:exclude_filter] = v
  end

  opts.on("-r", "--runs N", Integer, "Number of iterations (default: 1)") do |v|
    options[:runs] = v
  end
end

def add_action_options(opts, options)
  opts.on("--info", "Show server info only") do
    options[:info] = true
  end

  opts.on("--shutdown", "Shut down the server") do
    options[:shutdown] = true
  end

  opts.on("-v", "--verbose", "Show full test output") do
    options[:verbose] = true
  end
end

def add_info_options(opts)
  opts.on("-h", "--help", "Show this help") do
    puts opts
    exit
  end

  opts.on("-V", "--version", "Show version") do
    require "minitest/jruby/server"
    puts "mt-client #{Minitest::JRuby::Server::VERSION}"
    exit
  end
end

def parse_options
  options = { runs: 1 }
  OptionParser.new do |opts|
    opts.banner = "Usage: mt-client [options]"
    add_connection_options(opts, options)
    add_filter_options(opts, options)
    add_action_options(opts, options)
    add_info_options(opts)
  end.parse!
  options
end

def run_iteration(client, options, index)
  seed = options[:seed] ? options[:seed] + index : nil
  client.run_tests(
    seed: seed,
    include_filter: options[:include_filter],
    exclude_filter: options[:exclude_filter],
  )
end

def print_verbose_output(result)
  puts result[:output]
  puts
end

def execute_runs(client, fmt, options)
  times = []
  options[:runs].times do |i|
    result = run_iteration(client, options, i)
    times << result[:time]
    fmt.print_run_result(result)
    print_verbose_output(result) if options[:verbose]
  end
  times
end

options = parse_options

require "minitest/jruby/server"

config = Minitest::JRuby::Server::Config.new(
  **options.slice(:uri_file, :project_root).compact,
)
client = Minitest::JRuby::Server::Client.new(config: config)
fmt = Minitest::JRuby::Server::ResultFormatter.new

begin
  client.connect
rescue Minitest::JRuby::Server::ServerNotRunning, Minitest::JRuby::Server::ConnectionError => e
  warn e.message
  exit 1
end

if options[:info]
  fmt.print_server_info(client.info)
  exit
end

if options[:shutdown]
  client.shutdown_server
  puts "Server shut down."
  exit
end

fmt.print_server_info(client.info)

times = execute_runs(client, fmt, options)

fmt.print_summary(times: times) if options[:runs] > 1
